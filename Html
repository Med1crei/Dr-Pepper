<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dr Pepper | 23 Flavors, One of a Kind</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header id="navbar">
        <div class="logo">Dr Pepper</div>
        <nav>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#about">Our Story</a></li>
                <li><a href="#products">Lineup</a></li>
                <li><a href="#flavors">23 Flavors</a></li>
                <li><a href="#merch">Merch</a></li>
            </ul>
        </nav>
        <a href="#contact" class="btn btn-nav">Get in Touch</a>
    </header>

    <section id="home" class="hero section-hidden">
        <div class="hero-content">
            <h1>23 Flavors.</h1>
            <h1 class="highlight">One of a Kind.</h1>
            <p>Experience the bold, deeply satisfying taste that has defied expectations since 1885.</p>
            <a href="#products" class="btn btn-primary">Explore the Lineup</a>
        </div>
    </section>

    <section id="about" class="about section-hidden">
        <div class="container">
            <h2>The Waco Original</h2>
            <div class="timeline">
                <div class="timeline-item">
                    <h3>1885</h3>
                    <p>Created in Waco, Texas by pharmacist Charles Alderton, making it the oldest major soft drink in America.</p>
                </div>
                <div class="timeline-item">
                    <h3>1904</h3>
                    <p>Introduced to almost 20 million people at the World's Fair Exposition in St. Louis.</p>
                </div>
                <div class="timeline-item">
                    <h3>Today</h3>
                    <p>Still delivering that unexplainable, utterly unique blend of 23 secret flavors worldwide.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="products" class="products container section-hidden">
        <h2>The Lineup</h2>
        <div class="grid">
            <div class="card">
                <div class="card-img placeholder-img">Original</div>
                <h3>Dr Pepper</h3>
                <p>The classic, unmistakable taste.</p>
                <span class="nutrition">150 Calories | 40g Sugar</span>
            </div>
            <div class="card">
                <div class="card-img placeholder-img">Diet</div>
                <h3>Diet Dr Pepper</h3>
                <p>All the flavor, none of the guilt.</p>
                <span class="nutrition">0 Calories | 0g Sugar</span>
            </div>
            <div class="card">
                <div class="card-img placeholder-img">Zero Sugar</div>
                <h3>Zero Sugar</h3>
                <p>The 23 flavors you love, zero sugar.</p>
                <span class="nutrition">0 Calories | 0g Sugar</span>
            </div>
            <div class="card">
                <div class="card-img placeholder-img">Strawberries & Cream</div>
                <h3>Limited Edition</h3>
                <p>A sweet, creamy twist on the original.</p>
                <span class="nutrition">150 Calories | 39g Sugar</span>
            </div>
        </div>
    </section>

    <section id="flavors" class="flavors section-hidden">
        <div class="container">
            <h2>Unlock the 23 Flavors</h2>
            <p>Hover over the bubbles to guess the secret notes that make up our legendary blend.</p>
            <div class="flavor-grid" id="flavor-grid">
                </div>
            <div class="flavor-display" id="flavor-display">
                <h3>Hover a flavor!</h3>
            </div>
        </div>
    </section>

    <section id="promotions" class="promo section-hidden">
        <div class="promo-content">
            <h2>Pepper Perks</h2>
            <p>Scan your receipts. Earn points. Get exclusive Dr Pepper rewards.</p>
            <a href="#" class="btn btn-secondary">Join Now</a>
        </div>
    </section>

    <section id="merch" class="merch container section-hidden">
        <h2>Brand Shop</h2>
        <div class="grid">
            <div class="card merch-card">
                <div class="card-img placeholder-img">T-Shirt</div>
                <h3>Classic Logo Tee</h3>
                <p>$25.00</p>
                <button class="btn btn-primary">Add to Cart</button>
            </div>
            <div class="card merch-card">
                <div class="card-img placeholder-img">Cap</div>
                <h3>Vintage Trucker Hat</h3>
                <p>$20.00</p>
                <button class="btn btn-primary">Add to Cart</button>
            </div>
            <div class="card merch-card">
                <div class="card-img placeholder-img">Drinkware</div>
                <h3>Insulated Tumbler</h3>
                <p>$30.00</p>
                <button class="btn btn-primary">Add to Cart</button>
            </div>
        </div>
    </section>

    <footer id="contact">
        <div class="container footer-grid">
            <div class="newsletter">
                <h3>Stay Connected</h3>
                <form id="contact-form">
                    <input type="email" placeholder="Enter your email" required>
                    <button type="submit" class="btn btn-primary">Subscribe</button>
                </form>
            </div>
            <div class="socials">
                <h3>Follow Us</h3>
                <div class="social-links">
                    <a href="#">Instagram</a> | <a href="#">Twitter</a> | <a href="#">TikTok</a>
                </div>
            </div>
        </div>
        <div class="copyright">
            <p>&copy; 2026 Dr Pepper/Seven Up, Inc. All rights reserved. (Concept Website)</p>
        </div>
    </footer>

    <script src="script.js"></script>
</body>
</html>
